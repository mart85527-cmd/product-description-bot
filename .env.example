# ==========================================
# Переменные окружения для Text Genius Bot
# ==========================================
# Инструкция:
# 1. Скопируйте этот файл в .env (команда: cp .env.example .env)
# 2. Замените значения-заглушки на реальные
# 3. Никогда не коммитьте файл .env в Git!

# --- Telegram Bot ---
# Получите токен у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# --- YandexGPT API ---
# Создайте API-ключ и узнайте Folder ID в Yandex Cloud Console
YANDEXGPT_API_KEY=your_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here

# --- Администратор ---
# Узнайте свой Telegram ID через @userinfobot
ADMIN_ID=123456789

# --- Оплата ---
# Реквизиты для ручного пополнения баланса (СБП)
PAYMENT_DETAILS=СБП на номер +7 (XXX) XXX-XX-XX (Имя, Банк)

# --- Ценообразование ---
# Цена за одно описание (в рублях)
PRICE_PER_DESCRIPTION=50

# Размер пакета для скидки (шт.)
DISCOUNT_PACKAGE_SIZE=50

# Процент скидки на пакет
DISCOUNT_PERCENT=20
